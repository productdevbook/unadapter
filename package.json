{
  "name": "unadapter",
  "version": "0.2.0",
  "private": false,
  "description": "Universal, type-safe database adapter layer with a unified API for Drizzle, Prisma, Kysely, Knex, MongoDB, Sumak and in-memory backends",
  "keywords": [
    "adapter",
    "adapters",
    "database",
    "database-adapter",
    "drizzle",
    "drizzle-orm",
    "knex",
    "kysely",
    "memory",
    "mongodb",
    "orm",
    "prisma",
    "query-builder",
    "sql",
    "sumak",
    "type-safe",
    "typescript",
    "unadapter"
  ],
  "homepage": "https://github.com/productdevbook/unadapter#readme",
  "bugs": {
    "url": "https://github.com/productdevbook/unadapter/issues"
  },
  "license": "MIT",
  "author": "productdevbook <hi@productdevbook.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/productdevbook/unadapter.git"
  },
  "funding": "https://github.com/sponsors/productdevbook",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./drizzle": {
      "types": "./dist/adapters/drizzle/index.d.mts",
      "import": "./dist/adapters/drizzle/index.mjs"
    },
    "./knex": {
      "types": "./dist/adapters/knex/index.d.mts",
      "import": "./dist/adapters/knex/index.mjs"
    },
    "./kysely": {
      "types": "./dist/adapters/kysely/index.d.mts",
      "import": "./dist/adapters/kysely/index.mjs"
    },
    "./memory": {
      "types": "./dist/adapters/memory/index.d.mts",
      "import": "./dist/adapters/memory/index.mjs"
    },
    "./mongodb": {
      "types": "./dist/adapters/mongodb/index.d.mts",
      "import": "./dist/adapters/mongodb/index.mjs"
    },
    "./prisma": {
      "types": "./dist/adapters/prisma/index.d.mts",
      "import": "./dist/adapters/prisma/index.mjs"
    },
    "./sumak": {
      "types": "./dist/adapters/sumak/index.d.mts",
      "import": "./dist/adapters/sumak/index.mjs"
    },
    "./create": {
      "types": "./dist/adapters/create/index.d.mts",
      "import": "./dist/adapters/create/index.mjs"
    },
    "./types": {
      "types": "./dist/types/index.d.mts",
      "import": "./dist/types/index.mjs"
    },
    "./db": {
      "types": "./dist/db/index.d.mts",
      "import": "./dist/db/index.mjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.mts",
      "import": "./dist/utils/index.mjs"
    },
    "./generate": {
      "types": "./dist/generate/index.d.mts",
      "import": "./dist/generate/index.mjs"
    }
  },
  "scripts": {
    "build": "obuild && node scripts/verify-build.mjs",
    "dev": "vitest",
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint . --fix && oxfmt .",
    "fmt": "oxfmt .",
    "typecheck": "tsgo --noEmit",
    "test": "pnpm lint && pnpm typecheck && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage.enabled true",
    "test:coverage:badges": "vitest run --coverage.enabled true && node scripts/update-badges.mjs",
    "update:badges": "node scripts/update-badges.mjs",
    "prisma:normal:push": "prisma db push --config tests/prisma/normal-tests/prisma.config.ts --accept-data-loss",
    "prisma:number-id:push": "prisma db push --config tests/prisma/number-id-tests/prisma.config.ts --accept-data-loss",
    "bumpp": "bumpp package.json",
    "release": "pnpm build && bumpp --commit --tag --push --all",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "defu": "^6.1.7",
    "pathe": "^2.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/adapter-better-sqlite3": "7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@typescript/native-preview": "7.0.0-dev.20260429.1",
    "@vitest/coverage-v8": "^4.1.9",
    "better-sqlite3": "^12.11.1",
    "bumpp": "^11.1.0",
    "deepmerge": "^4.3.1",
    "drizzle-orm": "^0.45.2",
    "knex": "^3.2.10",
    "kysely": "^0.29.2",
    "mongodb": "^7.3.0",
    "mysql2": "^3.22.5",
    "obuild": "^0.4.37",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "sumak": "^0.0.16",
    "tarn": "^3.0.2",
    "tedious": "^19.2.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.11.1"
  },
  "packageManager": "pnpm@11.8.0"
}
